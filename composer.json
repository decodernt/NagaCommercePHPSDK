{
    "name": "nagacommerce/sdk",
    "description": "PHP SDK for the NagaCommerce REST API",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "NagaCommerce\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NagaCommerce\\SDK\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
